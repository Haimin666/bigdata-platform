# MySQL
MYSQL_ROOT_PASSWORD=rootpass

# 平台服务 JWT 密钥（生产务必更换）
JWT_SECRET=dev-secret-change-me-in-production-at-least-256-bits-long

# Linkis 网关。P1 默认 mock=true（不连真 Linkis 也能跑通计算演示）
LINKIS_MOCK=true
LINKIS_BASE_URL=http://linkis:9001

# OpenMetadata 数据血缘（P2）。直连现有实例，token 留空则血缘接口返回 503
# token 获取：OpenMetadata UI → Settings → Bots → Access Token
OPENMETADATA_BASE_URL=https://omd.corp.shiqiao.com
OPENMETADATA_TOKEN=

# DolphinScheduler 离线调度（P3）。直连现有实例，token 留空则调度接口返回 503
# token 获取：DS UI → 安全中心 → Token 管理 → 创建令牌
DOLPHINSCHEDULER_BASE_URL=http://olds.bigdata.shiqiao.com/dolphinscheduler
DOLPHINSCHEDULER_TOKEN=

# StreamPark 实时开发（P5）。直连现有实例，token 留空则实时接口返回 503
# token 获取：StreamPark UI → 个人中心 → Access Token；teamId 从 /team/list 拿到
# P5 仅只读（dashboard/project/env/cluster/team），不触发 build/deploy/start/cancel
STREAMPARK_BASE_URL=https://streamx.corp.shiqiao.com
STREAMPARK_TOKEN=
STREAMPARK_TEAM_ID=100000

# 前端访问平台服务的地址
NEXT_PUBLIC_PLATFORM_API=http://localhost:8088
CORS_ORIGINS=http://localhost:3000
